# Learner Agent Core - Environment Variables

# ===== REQUIRED =====

# Anthropic API Key (get yours at https://console.anthropic.com)
ANTHROPIC_API_KEY=your_api_key_here


# ===== OPTIONAL =====

# Server Configuration
# External port for accessing the application (default: 8000)
# Change this if port 8000 is already in use on your machine
PORT=8000

# LLM Models (defaults shown below)
LEARNER_MODEL=claude-sonnet-4-20250514
EXTRACTOR_MODEL=claude-haiku-4-5-20251001

# Application Environment
APP_ENV=production
LOG_LEVEL=info
